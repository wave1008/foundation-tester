<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="旧ID(v1)を使う" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_heal_schema"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_heal_schema"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="schema=v1" />

        <!-- ラベル固定・id のみ切替がヒール検証の核。schema に応じて btn_heal_v1/v2 を出し分ける。 -->
        <Button
            android:id="@+id/btn_heal_v1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="修復対象" />

        <Button
            android:id="@+id/btn_heal_v2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:visibility="gone"
            android:text="修復対象" />

        <TextView
            android:id="@+id/txt_heal_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="tapped=-" />

        <Button
            android:id="@+id/btn_heal_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="修復結果クリア" />
    </LinearLayout>
</ScrollView>
