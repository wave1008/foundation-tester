<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txt_launch_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="launch=0" />

        <TextView
            android:id="@+id/txt_session_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="session=0" />

        <Button
            android:id="@+id/btn_session_inc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="セッション+1" />

        <Button
            android:id="@+id/btn_reset_persisted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="永続カウンタをリセット" />

        <TextView
            android:id="@+id/txt_platform"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="platform=Android" />
    </LinearLayout>
</ScrollView>
