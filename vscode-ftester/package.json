{
  "name": "vscode-ftester",
  "displayName": "ftester",
  "description": "%ftester.extension.description%",
  "version": "0.0.351",
  "private": true,
  "publisher": "wave1008",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wave1008/foundation-tester.git",
    "directory": "vscode-ftester"
  },
  "bugs": {
    "url": "https://github.com/wave1008/foundation-tester/issues"
  },
  "homepage": "https://github.com/wave1008/foundation-tester/tree/main/vscode-ftester#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Testing"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:Package.swift"
  ],
  "contributes": {
    "configuration": {
      "title": "ftester",
      "properties": {
        "ftester.binaryPath": {
          "type": "string",
          "default": ".build/debug/ftester",
          "description": "%ftester.config.binaryPath.description%"
        },
        "ftester.project": {
          "type": "string",
          "default": "",
          "description": "%ftester.config.project.description%"
        },
        "ftester.profile": {
          "type": "string",
          "default": "",
          "description": "%ftester.config.profile.description%"
        },
        "ftester.platform": {
          "type": "string",
          "enum": [
            "ios",
            "android"
          ],
          "default": "ios",
          "description": "%ftester.config.platform.description%"
        },
        "ftester.port": {
          "type": "number",
          "default": 0,
          "description": "%ftester.config.port.description%"
        },
        "ftester.serial": {
          "type": "string",
          "default": "",
          "description": "%ftester.config.serial.description%"
        },
        "ftester.buildBeforeRun": {
          "type": "boolean",
          "default": true,
          "description": "%ftester.config.buildBeforeRun.description%"
        },
        "ftester.heal": {
          "type": "boolean",
          "default": false,
          "description": "%ftester.config.heal.description%"
        },
        "ftester.monitorInterval": {
          "type": "number",
          "default": 2,
          "minimum": 0.5,
          "description": "%ftester.config.monitorInterval.description%"
        },
        "ftester.monitorMaxWidth": {
          "type": "number",
          "default": 960,
          "minimum": 240,
          "maximum": 1600,
          "description": "%ftester.config.monitorMaxWidth.description%"
        },
        "ftester.liveFps": {
          "type": "number",
          "default": 12,
          "minimum": 3,
          "maximum": 30,
          "description": "%ftester.config.liveFps.description%"
        },
        "ftester.iosStreamEnabled": {
          "type": "boolean",
          "default": true,
          "description": "%ftester.config.iosStreamEnabled.description%"
        },
        "ftester.androidStreamEnabled": {
          "type": "boolean",
          "default": true,
          "description": "%ftester.config.androidStreamEnabled.description%"
        },
        "ftester.streamCodec": {
          "type": "string",
          "enum": [
            "h264",
            "mjpeg"
          ],
          "default": "h264",
          "description": "%ftester.config.streamCodec.description%"
        },
        "ftester.liveControlOnRun": {
          "type": "boolean",
          "default": true,
          "description": "%ftester.config.liveControlOnRun.description%"
        },
        "ftester.autoRepairBridge": {
          "type": "boolean",
          "default": true,
          "description": "%ftester.config.autoRepairBridge.description%"
        },
        "ftester.autoRepairDeviceHealth": {
          "type": "boolean",
          "default": false,
          "description": "%ftester.config.autoRepairDeviceHealth.description%"
        },
        "ftester.showOnlyFailedTests": {
          "type": "boolean",
          "default": false,
          "description": "%ftester.config.showOnlyFailedTests.description%"
        },
        "ftester.language": {
          "type": "string",
          "enum": [
            "auto",
            "ja",
            "en"
          ],
          "default": "auto",
          "description": "%ftester.config.language.description%"
        }
      }
    },
    "debuggers": [
      {
        "type": "ftester",
        "label": "ftester scenario",
        "languages": [
          "swift"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "project",
              "scenario"
            ],
            "properties": {
              "project": {
                "type": "string",
                "description": "%ftester.debugger.project.description%"
              },
              "scenario": {
                "type": "string",
                "description": "%ftester.debugger.scenario.description%"
              },
              "dryRun": {
                "type": "boolean",
                "default": false,
                "description": "%ftester.debugger.dryRun.description%"
              },
              "stopOnEntry": {
                "type": "boolean",
                "default": false,
                "description": "%ftester.debugger.stopOnEntry.description%"
              },
              "skipBuild": {
                "type": "boolean",
                "default": false,
                "description": "%ftester.debugger.skipBuild.description%"
              },
              "heal": {
                "type": "boolean",
                "default": false,
                "description": "%ftester.debugger.heal.description%"
              },
              "profile": {
                "type": "string",
                "description": "%ftester.debugger.profile.description%"
              },
              "platform": {
                "type": "string",
                "enum": [
                  "ios",
                  "android"
                ],
                "description": "%ftester.debugger.platform.description%"
              },
              "port": {
                "type": "number",
                "description": "%ftester.debugger.port.description%"
              },
              "serial": {
                "type": "string",
                "description": "%ftester.debugger.serial.description%"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "ftester",
            "request": "launch",
            "name": "%ftester.debugger.initialConfig.name%",
            "project": "",
            "scenario": ""
          }
        ]
      }
    ],
    "breakpoints": [
      {
        "language": "swift"
      }
    ],
    "views": {
      "test": [
        {
          "id": "ftesterSteps",
          "name": "%ftester.view.ftesterSteps.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "ftester.refreshScenarios",
        "title": "%ftester.command.refreshScenarios.title%",
        "category": "ftester"
      },
      {
        "command": "ftester.selectProject",
        "title": "%ftester.command.selectProject.title%",
        "category": "ftester",
        "icon": "$(folder-library)"
      },
      {
        "command": "ftester.showSteps",
        "title": "%ftester.command.showSteps.title%",
        "category": "ftester"
      },
      {
        "command": "ftester.refreshSteps",
        "title": "%ftester.command.refreshSteps.title%",
        "category": "ftester",
        "icon": "$(refresh)"
      },
      {
        "command": "ftester.showDeviceMonitor",
        "title": "%ftester.command.showDeviceMonitor.title%",
        "category": "ftester",
        "icon": "$(device-mobile)"
      },
      {
        "command": "ftester.showLiveControl",
        "title": "%ftester.command.showLiveControl.title%",
        "category": "ftester"
      },
      {
        "command": "ftester.showResultsDashboard",
        "title": "%ftester.command.showResultsDashboard.title%",
        "category": "ftester"
      },
      {
        "command": "ftester.selectProfile",
        "title": "%ftester.command.selectProfile.title%",
        "category": "ftester"
      },
      {
        "command": "ftester.validateProfiles",
        "title": "%ftester.command.validateProfiles.title%",
        "category": "ftester"
      },
      {
        "command": "ftester.deleteScenario",
        "title": "%ftester.command.deleteScenario.title%",
        "category": "ftester"
      },
      {
        "command": "ftester.rerunFailedTests",
        "title": "%ftester.command.rerunFailedTests.title%",
        "category": "ftester"
      },
      {
        "command": "ftester.copyTestName",
        "title": "%ftester.command.copyTestName.title%",
        "category": "ftester"
      },
      {
        "command": "ftester.openScenarioReport",
        "title": "%ftester.command.openScenarioReport.title%",
        "category": "ftester"
      },
      {
        "command": "ftester.enableFailedTestsFilter",
        "title": "%ftester.command.enableFailedTestsFilter.title%",
        "category": "ftester",
        "icon": "$(filter)"
      },
      {
        "command": "ftester.disableFailedTestsFilter",
        "title": "%ftester.command.disableFailedTestsFilter.title%",
        "category": "ftester",
        "icon": "$(filter-filled)"
      }
    ],
    "menus": {
      "testing/item/context": [
        {
          "command": "ftester.showSteps",
          "group": "navigation"
        },
        {
          "command": "ftester.rerunFailedTests",
          "when": "controllerId == 'ftester'",
          "group": "y_rerun@1"
        },
        {
          "command": "ftester.copyTestName",
          "when": "controllerId == 'ftester'",
          "group": "y_rerun@2"
        },
        {
          "command": "ftester.openScenarioReport",
          "when": "controllerId == 'ftester'",
          "group": "y_rerun@3"
        },
        {
          "command": "ftester.deleteScenario",
          "when": "controllerId == 'ftester' && !(testId =~ /^folder:/)",
          "group": "z_delete"
        }
      ],
      "view/title": [
        {
          "command": "ftester.refreshSteps",
          "when": "view == ftesterSteps",
          "group": "navigation"
        },
        {
          "command": "ftester.selectProject",
          "when": "view == workbench.view.testing",
          "group": "navigation@0"
        },
        {
          "command": "ftester.enableFailedTestsFilter",
          "when": "view == workbench.view.testing && !ftester.failedTestsFilterEnabled",
          "group": "navigation"
        },
        {
          "command": "ftester.disableFailedTestsFilter",
          "when": "view == workbench.view.testing && ftester.failedTestsFilterEnabled",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ftester.copyTestName",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "focusedView == 'workbench.view.testing'"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "**/Projects/*/profiles/runs/*.json",
        "url": "./schemas/run-profile.schema.json"
      },
      {
        "fileMatch": "**/Projects/*/profiles/apps/*.json",
        "url": "./schemas/app-profile.schema.json"
      },
      {
        "fileMatch": "**/Projects/*/profiles/machines/*.json",
        "url": "./schemas/machine-profile.schema.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.mjs && tsc --noEmit",
    "watch": "node esbuild.mjs --watch",
    "test": "node esbuild.mjs --tests && node --test out-test/*.test.mjs",
    "package": "vsce package",
    "install-local": "bash scripts/install-local.sh"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.65.0",
    "@vscode/debugprotocol": "^1.65.0"
  }
}
